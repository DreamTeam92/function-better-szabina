{
  "name": "lovable-tagger",
  "version": "1.3.3",
  "description": "Vite plugins for component tagging and Tailwind config extraction",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist"
  ],
  "keywords": [
    "vite",
    "plugin",
    "component",
    "tagger",
    "tailwind"
  ],
  "author": "Emil Fagerholm",
  "license": "MIT",
  "peerDependencies": {
    "vite": ">=5.0.0 <9.0.0"
  },
  "dependencies": {
    "esbuild": "^0.25.0",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@types/node": "22.13.13",
    "rimraf": "^5.0.10",
    "tsdown": "^0.22.5",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lovablelabs/lovable.git",
    "directory": "npm-packages/tagger"
  },
  "scripts": {
    "build": "tsdown",
    "check:package": "tmp=$(mktemp -d) && pnpm pack --out \"$tmp/pkg.tgz\" && tar -xzf \"$tmp/pkg.tgz\" -C \"$tmp\" && publint \"$tmp/package\" --strict && attw \"$tmp/pkg.tgz\"",
    "typecheck": "tsgo --noEmit",
    "dev": "tsdown --watch",
    "test": "vitest",
    "clean": "rimraf dist",
    "coverage": "vitest run --coverage"
  }
}